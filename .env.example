# OpenClaw Jarvis — Environment Variables Template
# Copie para .env e preencha os valores reais
# NEVER commit .env (git-crypt encrypted)

# === GitHub & GitHub Copilot ===
GITHUB_TOKEN=ghp_your_token_here

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz1234567890
TELEGRAM_CHAT_ID=your_chat_id_here

# === Google OAuth 2.0 ===
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# === Firefly III ===
FIREFLY_URL=http://firefly-iii:8080
FIREFLY_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# === Storage Paths (Pi mounted volumes) ===
EXTERNAL_MOUNT=/mnt/external
OPENCLAW_DATA=${EXTERNAL_MOUNT}/openclaw
LOGS_DIR=${EXTERNAL_MOUNT}/logs
BACKUPS_DIR=${EXTERNAL_MOUNT}/backups
FIREFLY_DATA=${EXTERNAL_MOUNT}/firefly

# === OpenClaw Configuration ===
OPENCLAW_MODEL=copilot
OPENCLAW_AGENT_ID=jarvis
OPENCLAW_LOG_LEVEL=info

# === Feature Flags ===
ENABLE_WHATSAPP_SKILL=true
ENABLE_TRAVELY_SEARCH=true
ENABLE_FLIGHT_SEARCH=true
