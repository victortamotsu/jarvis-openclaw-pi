// openclaw.json — Jarvis Personal Assistant
// Schema: OpenClaw JSON5 (strict validation — only known keys allowed)
// Last updated: 2026-03-08 — Phase 8.2 (T090): added skills.entries with 6 skills + TAVILY_API_KEY
{
  agents: {
    defaults: {
      model: {
        primary: "github-copilot/gpt-4.1", // multiplier 0 — sem débito de premium requests
      },
      workspace: "/home/node/.openclaw/workspace",
    },
  },
  channels: {
    telegram: {
      botToken: "${TELEGRAM_BOT_TOKEN}",
      // allowFrom: sem isso o bot responde com codigo de pareamento (dmPolicy: pairing)
      allowFrom: ["${TELEGRAM_CHAT_ID}"],
    },
  },
  skills: {
    entries: {
      "tavily-search": {
        enabled: true,
        env: {
          TAVILY_API_KEY: "${TAVILY_API_KEY}",
        },
      },
      "flight-search": {
        enabled: true,
        env: {
          SERP_API_KEY: "${SERP_API_KEY}",
        },
      },
      "google-tasks": {
        enabled: true,
        env: {
          GOOGLE_CLIENT_ID: "${GOOGLE_CLIENT_ID}",
          GOOGLE_CLIENT_SECRET: "${GOOGLE_CLIENT_SECRET}",
          GOOGLE_REFRESH_TOKEN: "${GOOGLE_REFRESH_TOKEN}",
        },
      },
      "firefly-finance": {
        enabled: true,
        env: {
          FIREFLY_URL: "http://firefly-iii:8080",
          FIREFLY_TOKEN: "${FIREFLY_TOKEN}",
        },
      },
      "travel-monitor": {
        enabled: true,
      },
      "code-agent": {
        enabled: true,
        env: {
          GITHUB_TOKEN: "${GITHUB_TOKEN}",
        },
      },
    },
  },
  // MCP servers started as stdio child processes by OpenClaw Gateway
  mcp_servers: [
    {
      name: "airbnb",
      command: "npx",
      args: ["-y", "@openbnb/mcp-server-airbnb"],
      // robots.txt compliance active by default (no --ignore-robots-txt)
      // If smoke test shows majority of searches fail, add: args: ["-y", "@openbnb/mcp-server-airbnb", "--ignore-robots-txt"]
    },
  ],
}
