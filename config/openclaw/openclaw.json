// openclaw.json — Jarvis Personal Assistant
// Schema: OpenClaw JSON5 (strict validation — only known keys allowed)
// Last updated: 2026-03-14 — Phase 10 (T103): model gpt-4.1, SERP_API_KEY, airbnb skill
{
  agents: {
    defaults: {
      model: {
        primary: "github-copilot/gpt-4.1", // multiplier 0 — sem débito de premium requests
      },
      workspace: "/home/node/.openclaw/workspace",
    },
  },
  commands: {
    native: "auto",
    nativeSkills: "auto",
    restart: true,
    ownerDisplay: "raw",
  },
  channels: {
    telegram: {
      enabled: true,
      dmPolicy: "pairing",
      botToken: "${TELEGRAM_BOT_TOKEN}",
      allowFrom: ["${TELEGRAM_CHAT_ID}"],
      groupPolicy: "allowlist",
      streaming: "partial",
    },
  },
  skills: {
    entries: {
      "tavily-search": {
        enabled: true,
        env: {
          TAVILY_API_KEY: "${TAVILY_API_KEY}",
        },
      },
      "flight-search": {
        enabled: true,
        env: {
          SERP_API_KEY: "${SERP_API_KEY}",
        },
      },
      "airbnb": {
        enabled: true,
      },
      "google-tasks": {
        enabled: true,
        env: {
          GOOGLE_CLIENT_ID: "${GOOGLE_CLIENT_ID}",
          GOOGLE_CLIENT_SECRET: "${GOOGLE_CLIENT_SECRET}",
          GOOGLE_REFRESH_TOKEN: "${GOOGLE_REFRESH_TOKEN}",
        },
      },
      "firefly-finance": {
        enabled: true,
        env: {
          FIREFLY_URL: "http://firefly-iii:8080",
          FIREFLY_TOKEN: "${FIREFLY_TOKEN}",
        },
      },
      "travel-monitor": {
        enabled: true,
      },
      "code-agent": {
        enabled: true,
        env: {
          GITHUB_TOKEN: "${GITHUB_TOKEN}",
        },
      },
    },
  },
